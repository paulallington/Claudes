{
  "name": "claudes",
  "version": "1.9.28",
  "description": "Multi-column Claude Code terminal desktop app",
  "author": {
    "name": "The Code Guy",
    "email": "noreply@thecodeguy.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pty-server": "node pty-server.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:publish": "electron-builder --publish always",
    "test": "node --test \"test/*.test.js\""
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0",
    "prismjs": "^1.30.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "overrides": {
    "tmp": "^0.2.6",
    "brace-expansion@>=5.0.0 <5.0.6": "^5.0.6"
  },
  "build": {
    "appId": "com.thecodeguy.claudes",
    "productName": "Claudes",
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "pty-server.js",
      "icon-tray.ico",
      "icon-tray.png",
      "node_modules/node-pty/**/*",
      "node_modules/ws/**/*"
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "platform-detect.js",
      "index.html",
      "styles.css",
      "pty-server.js",
      "lib/**/*",
      "icon.ico",
      "icon.png",
      "icon-tray.ico",
      "icon-tray.png",
      "claude-icon.png",
      "claude-small.png",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon-tray.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg"
        },
        {
          "target": "zip"
        }
      ],
      "icon": "icon.png",
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "signIgnore": [
        "/Contents/Resources/app.asar.unpacked/node_modules/node-pty/.*"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon-tray.ico",
      "uninstallerIcon": "icon-tray.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage"
        },
        {
          "target": "deb"
        }
      ],
      "icon": "icon.png",
      "category": "Development",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "paulallington",
      "repo": "Claudes"
    }
  }
}
